# ============================================================
#  保密相关：这些文件包含真实 key，绝不能进 git
# ============================================================
backend/config.yaml
frontend/.env.local
frontend/.env.local.*
!frontend/.env.local.example

# ============================================================
#  生成物 / 缓存 / 依赖
# ============================================================
backend/.cache/
backend/**/__pycache__/
backend/*.egg-info/
backend/build/
backend/dist/

frontend/node_modules/
frontend/dist/
frontend/.vite/

# ============================================================
#  Python 通用
# ============================================================
__pycache__/
*.py[cod]
*.so
*.egg
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/
venv/

# ============================================================
#  Node 通用
# ============================================================
*.log
npm-debug.log*
.npm/

# ============================================================
#  IDE / OS
# ============================================================
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db
